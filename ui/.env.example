# eko UI - Environment Configuration
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# URL of the eko daemon/server API
# Default: http://localhost:8080
NEXT_PUBLIC_EKO_API_URL=http://localhost:8080

# Port the Next.js dev server listens on (used by `npm run dev`)
# Default: 3000
PORT=3000

# Base URL where this UI is served (used for absolute links and redirects)
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
